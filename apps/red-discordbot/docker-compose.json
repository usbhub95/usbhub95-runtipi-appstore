{
  "services": [
    {
      "name": "redbot",
      "image": "phasecorex/red-discordbot",
      "environment": {
        "TOKEN": "your_bot_token_goes_here",
        "PREFIX": ".",
        "TZ": "Australia/Sydney"
      },
      "volumes": [
        {
          "hostPath": "./redbot",
          "containerPath": "/data",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ]
    }
  ]
}